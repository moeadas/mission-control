  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "sh -c 'trap \"kill 0\" EXIT; tsx scripts/task-worker.ts & next dev'",
    "build": "next build",
    "start": "sh -c 'trap \"kill 0\" EXIT; tsx scripts/task-worker.ts & next start'",
    "start:web": "next start",
    "worker": "tsx scripts/task-worker.ts",
    "lint": "next lint",
    "test": "tsx --test tests/*.test.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@types/jszip": "^3.4.0",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
