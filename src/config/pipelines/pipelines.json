                "Top competitors identified",
                "Competitor backlink profiles analyzed",
                "Content strategies compared",
                "Gap analysis completed",
                "Opportunities mapped"
              ]
            }
          ]
        },
        {
          "id": "strategy",
          "name": "Strategy Development",
          "color": "#ffd166",
          "activities": [
            {
              "id": "strategy-1",
